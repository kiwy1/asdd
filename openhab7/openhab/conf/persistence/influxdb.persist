// InfluxDB persistence for virtual items
Strategies {
    everyMinute : "0 * * * * ?"
    every5Minutes : "0 */5 * * * ?"
}

Items {
    V_Temp_Living, V_Temp_Bedroom, V_Temp_Kitchen,
    V_Hum_Living, V_Hum_Bedroom,
    V_Light_Bedroom, V_Switch_Kitchen,
    V_Power_Consumption, V_CO2_Level : strategy = everyChange, every5Minutes
}

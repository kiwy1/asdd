# OpenHAB7 Stack - Environment Configuration
# Copy to .env and set values. Do not commit .env to Git.

# --- Timezone ---
TZ=Europe/Kyiv

# --- OpenHAB ---
OPENHAB_HTTP_PORT=8080
OPENHAB_HTTPS_PORT=8443

# --- InfluxDB ---
INFLUXDB_ADMIN_USER=admin
INFLUXDB_ADMIN_PASSWORD=change-me-influxdb-password
INFLUXDB_ORG=openhab
INFLUXDB_BUCKET=openhab
INFLUXDB_TOKEN=change-me-influxdb-token
INFLUXDB_RETENTION=52w
INFLUXDB_PORT=8087

# --- Grafana ---
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-grafana-password
GRAFANA_PORT=3000

# --- MQTT (Mosquitto) ---
MQTT_PORT=1883
MQTT_WS_PORT=9001

# --- Nginx Reverse Proxy ---
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# --- Virtual Simulator ---
SIM_INTERVAL=10
